# ============================================================
# Project ARES — Root Environment Configuration Sample
# Copy this file to .env and fill in your values.
# This file is read by Docker Compose and applies to all
# central services: ares-backend and ares-worker.
#
# NOTE: The ares-mcp-server has its own .sample.env under
# ares-mcp-server/ — that is the developer's local config.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL Cluster
# ------------------------------------------------------------
DB_HOST=postgres-cluster
DB_PORT=5432
DB_NAME=ares
DB_USER=ares_admin
DB_PASSWORD=your_secure_password_here
ARES_ROOT_ADMINS=your_github_username

# ------------------------------------------------------------
# Spring Boot
# ------------------------------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------------------------
# GitHub Authentication
# Required for: Copilot CLI (LLM completions), Copilot API
# (embeddings), and authenticated git clones inside the worker.
# ------------------------------------------------------------
GITHUB_PAT=github_pat_your_token_here

# ------------------------------------------------------------
# Inference / Ollama
# Points ares-backend and ares-worker at the Ollama sidecar.
# Do not change this when using Docker Compose — the sidecar
# is reachable at http://inference-sidecar:11434 on the
# internal Docker network.
# ------------------------------------------------------------
INFERENCE_URL=http://inference-sidecar:11434
ARES_GPU_COUNT=1

# ------------------------------------------------------------
# Ollama Embedding Models
# These are used when COPILOT_EMBEDDING_MODEL is not set.
# The inference-sidecar pre-warms both models on startup.
# ------------------------------------------------------------
CODE_EMBEDDING_MODEL=nomic-embed-text
DOC_EMBEDDING_MODEL=bge-m3

# ------------------------------------------------------------
# Copilot LLM Model (for text generation / chat completions)
# Used by ares-worker's fetch_completion() via the Copilot CLI.
# Valid values: auto, gpt-4o, claude-opus-4.6, gemini-flash-3.5
# Leave empty to use local Ollama (llama3) for completions.
# ------------------------------------------------------------
COPILOT_LLM_MODEL=auto

# ------------------------------------------------------------
# Copilot Embedding Model (for vector embedding)
# When set, ares-worker calls the Copilot API embedding endpoint
# (api.githubcopilot.com/embeddings) using GITHUB_PAT for token
# exchange. Data is routed through GitHub's enterprise
# infrastructure — NOT the public OpenAI API.
# Valid values: text-embedding-3-small, text-embedding-ada-002
# Leave empty to use local Ollama embeddings (recommended for
# air-gapped or offline environments).
# ------------------------------------------------------------
COPILOT_EMBEDDING_MODEL=
