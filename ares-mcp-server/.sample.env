# ARES MCP Server - Environment Configuration Template
# Copy this file to '.env' and fill in your local values.
# This config applies ONLY to the ares-mcp-server process running
# on your local machine. It does not affect the Docker containers.

# ---------------------------------------------------------------
# Backend Orchestrator Address
# ---------------------------------------------------------------
ARES_BACKEND_URL="http://localhost:8080"

# ---------------------------------------------------------------
# Developer Credentials
# ---------------------------------------------------------------
GITHUB_PAT="YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
NOTION_TOKEN="YOUR_NOTION_INTEGRATION_TOKEN"

# ---------------------------------------------------------------
# Workspace Path & Database Settings
# ---------------------------------------------------------------
# ARES_WORKSPACE_PATH: The absolute path of the workspace to target.
# If unset, the server dynamically queries the client workspace root.
# ARES_WORKSPACE_PATH="/absolute/path/to/workspace"

# ARES_DB_PATH: Custom path for SQLite-vec database file.
# Defaults to `<workspace-path>/.ares/local_context.db` if unset.
# ARES_DB_PATH="/absolute/path/to/database.db"

# ---------------------------------------------------------------
# Harvester Configuration
# List of grammar identifiers configured in grammars.json to be
# dynamically loaded for AST-based chunking.
# ---------------------------------------------------------------
SUPPORTED_GRAMMARS="typescript,java,python"

# ---------------------------------------------------------------
# Local Ollama Inference URL
# Used by the harvester when COPILOT_EMBEDDING_MODEL is not set.
# If running inference-sidecar via Docker, it is mapped to
# localhost:11434. Leave as-is for the default setup.
# ---------------------------------------------------------------
INFERENCE_URL="http://localhost:11434"

# ---------------------------------------------------------------
# Job Polling Interval
# How often (ms) the MCP server polls ares-backend for job status.
# ---------------------------------------------------------------
POLLING_INTERVAL_MS=3000

# ---------------------------------------------------------------
# Dynamic Routing Execution Matrix Configuration
# Specifies which inference provider/model is used for each phase
# of ARES orchestration. These are forwarded to ares-backend.
# ---------------------------------------------------------------
EMBEDDING_GENERATION="ollama"
KNOWLEDGE_RETRIEVAL_RANKING="ollama"
COMPLIANCE_EVALUATION="gemini-flash-3.5"
PR_SYNTHESIS="claude-opus-4.6"

# ---------------------------------------------------------------
# Copilot Embedding Model (developer's local choice)
# Controls how the harvester embeds code chunks into the local
# sqlite-vec store. This is YOUR machine's setting — independent
# of what the central ares-backend/ares-worker use.
#
# When set: calls the Copilot API embedding endpoint directly
#   using GITHUB_PAT to exchange for a short-lived session token.
#   The Copilot CLI is NOT used for embeddings.
#   Valid values: "text-embedding-3-small" | "text-embedding-ada-002"
#   Requires GITHUB_PAT with an active Copilot subscription.
# When unset: uses local Ollama at INFERENCE_URL (default).
# ---------------------------------------------------------------
# COPILOT_EMBEDDING_MODEL="text-embedding-3-small"

# ---------------------------------------------------------------
# Copilot LLM Model (for chat/planning forwarded to backend)
# When set, this model name is forwarded to ares-backend via the
# X-ARES-COPILOT-LLM-MODEL header, which the backend passes to
# the ares-worker Copilot CLI for text generation.
# Valid values: auto, gpt-4o, claude-opus-4.6, gemini-flash-3.5
# When unset: backend uses its own COPILOT_LLM_MODEL from root .env.
# ---------------------------------------------------------------
# COPILOT_LLM_MODEL="auto"
